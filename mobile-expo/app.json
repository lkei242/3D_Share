{
  "expo": {
    "name": "3D Share",
    "slug": "mobile-expo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon-app.png",
    "userInterfaceStyle": "automatic",
    "backgroundColor": "#121212",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "backgroundColor": "#121212",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon-app.png",
        "backgroundColor": "#121212"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ],
      "package": "com.germanrom.threeDshare"
    },
    "androidStatusBar": {
      "barStyle": "light-content",
      "translucent": true,
      "backgroundColor": "#00000000"
    },
    "plugins": [
      "@react-native-community/datetimepicker",
      [
        "expo-audio",
        {
          "microphonePermission": "Permite que $(PRODUCT_NAME) acceda al micrófono para grabar audio.",
          "enableBackgroundPlayback": true,
          "enableBackgroundRecording": false
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Permite que $(PRODUCT_NAME) acceda a la cámara."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon-app.png",
          "color": "#546F1C"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Permite que $(PRODUCT_NAME) acceda a tu ubicación.",
          "locationWhenInUsePermission": "Permite que $(PRODUCT_NAME) acceda a tu ubicación mientras usas la app."
        }
      ],
      "expo-video",
      "expo-font"
    ],
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "3301b621-186b-41de-8b98-c8cebf5befda"
      }
    }
  }
}
